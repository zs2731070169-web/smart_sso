# smart_sso 配置(环境变量以 SSO_ 为前缀)

# JWT issuer claim(消费方 smart_talkflow 的 SSO_ISSUER 须与此一致)
SSO_ISSUER=smart_sso
# RSA 私钥路径(首次启动自动生成,之后复用;勿提交到版本库)
SSO_PRIVATE_KEY_PATH=keys/private.pem
# JWT 有效期(秒)
SSO_TOKEN_TTL=7200
# 监听端口
SSO_PORT=48081

# ---- 身份源(/login 认证后端)----
# stub:硬编码用户联调(见 app/users.py);yudao:委托 yudao-office 认证
SSO_IDENTITY_SOURCE=stub
# yudao-office 地址(仅 IDENTITY_SOURCE=yudao 时用)
SSO_YUDAO_BASE_URL=http://localhost:48080
# 默认租户(yudao tenant-id 头)
SSO_DEFAULT_TENANT_ID=1